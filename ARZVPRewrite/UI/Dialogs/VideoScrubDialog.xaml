<Window
    x:Class="ARZVPRewrite.UI.Pages.VideoScrubDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ico="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:loc="clr-namespace:ARZVPRewrite.Extensions"
    xmlns:local="clr-namespace:ARZVPRewrite.UI.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
    Title="{loc:Translation dialog.videoscrub}"
    Width="1000"
    Height="600"
    Background="{DynamicResource PrimaryBackground}"
    Closing="ScrubDialogClosing"
    FontFamily="{DynamicResource Inter}"
    Foreground="{DynamicResource PrimaryForeground}"
    Loaded="ScrubDialogLoaded"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ARZVPRewrite;component/UI/Resources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Name="TimeText"
            Margin="5"
            HorizontalAlignment="Center"
            FontSize="16"
            FontWeight="Bold"
            Text="00:00:00 / 00:00:00" />

        <Border
            Grid.Row="1"
            Margin="5"
            Background="Black">
            <vlc:VideoView x:Name="Preview" />
        </Border>

        <StackPanel
            Grid.Row="2"
            Margin="5"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Button
                x:Name="PlayPauseBtn"
                Margin="5"
                Click="PlayPauseBtnClicked">
                <Button.Content>
                    <ico:MaterialIcon
                        x:Name="PlayPauseIcon"
                        IconSize="24"
                        Kind="Play" />
                </Button.Content>
            </Button>

            <Button
                x:Name="StopBtn"
                Margin="5"
                Click="StopBtnClicked">
                <Button.Content>
                    <ico:MaterialIcon IconSize="24" Kind="Stop" />
                </Button.Content>
            </Button>
        </StackPanel>

        <Slider
            x:Name="ScrubSlider"
            Grid.Row="3"
            Margin="5"
            PreviewMouseDown="ScrubSliderPreviewMouseDown"
            PreviewMouseUp="ScrubSliderPreviewMouseUp"
            ValueChanged="ScrubSliderValueChanged" />

        <Button
            x:Name="OkBtn"
            Grid.Row="4"
            Margin="5"
            Click="OkBtnClicked">
            <Button.Content>
                <StackPanel Orientation="Horizontal">
                    <ico:MaterialIcon IconSize="24" Kind="Check" />
                    <TextBlock
                        Margin="10"
                        VerticalAlignment="Center"
                        FontSize="16"
                        Text="OK" />
                </StackPanel>
            </Button.Content>
        </Button>
    </Grid>
</Window>
