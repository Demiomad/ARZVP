<Window
    x:Class="ARZVPRewrite.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ico="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:loc="clr-namespace:ARZVPRewrite.Extensions"
    xmlns:local="clr-namespace:ARZVPRewrite.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pages="clr-namespace:ARZVPRewrite.UI.Pages"
    Title="{loc:Translation window.arzvp.title}"
    Width="1200"
    Height="700"
    Background="{DynamicResource PrimaryBackground}"
    FontFamily="{DynamicResource Inter}"
    Foreground="{DynamicResource PrimaryForeground}"
    Icon="pack://application:,,,/ARZVPRewrite;component/Resources/UI/Icon.ico"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ARZVPRewrite;component/UI/Resources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Margin="5"
            Background="{DynamicResource SecondaryBackground}"
            CornerRadius="8">
            <StackPanel x:Name="Sidebar" Orientation="Vertical">
                <StackPanel
                    Margin="5"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        FontSize="32"
                        FontWeight="Bold"
                        Text="ARZVP"
                        TextAlignment="Center" />
                    <TextBlock
                        Margin="5"
                        VerticalAlignment="Center"
                        FontSize="16"
                        Text="v2.2.1" />
                </StackPanel>

                <Button
                    x:Name="HomeBtn"
                    Margin="5"
                    Click="HomeBtnClicked">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <ico:MaterialIcon IconSize="24" Kind="Home" />
                            <TextBlock
                                Margin="10"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Text="{loc:Translation button.home}" />
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button
                    x:Name="TemplatesBtn"
                    Margin="5"
                    Click="TemplatesBtnClicked">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <ico:MaterialIcon IconSize="24" Kind="Apps" />
                            <TextBlock
                                Margin="10"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Text="{loc:Translation button.templates}" />
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button
                    x:Name="GenerateBtn"
                    Margin="5"
                    Click="GenerateBtnClicked">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <ico:MaterialIcon IconSize="24" Kind="AutoAwesome" />
                            <TextBlock
                                Margin="10"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Text="{loc:Translation button.generate}" />
                        </StackPanel>
                    </Button.Content>
                </Button>

                <Button
                    x:Name="SettingsBtn"
                    Margin="5"
                    Click="SettingsBtnClicked">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal">
                            <ico:MaterialIcon IconSize="24" Kind="Settings" />
                            <TextBlock
                                Margin="10"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Text="{loc:Translation button.settings}" />
                        </StackPanel>
                    </Button.Content>
                </Button>
            </StackPanel>
        </Border>

        <ContentControl x:Name="MainContent" Grid.Column="1">
            <ContentControl.Content>
                <pages:HomePage />
            </ContentControl.Content>
        </ContentControl>
    </Grid>
</Window>
