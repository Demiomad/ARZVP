<UserControl
    x:Class="ARZVPRewrite.UI.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:loc="clr-namespace:ARZVPRewrite.Extensions"
    xmlns:local="clr-namespace:ARZVPRewrite.UI.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Background="{DynamicResource PrimaryBackground}"
    FontFamily="{DynamicResource Inter}"
    Foreground="{DynamicResource PrimaryForeground}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ARZVPRewrite;component/UI/Resources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Margin="5"
            FontSize="32"
            FontWeight="Bold"
            Text="{loc:Translation page.home.heading}" />
        <TextBlock
            Grid.Row="1"
            Margin="5"
            Text="{loc:Translation page.home.content}" />
    </Grid>
</UserControl>
