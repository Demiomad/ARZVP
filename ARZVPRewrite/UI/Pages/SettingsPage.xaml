<UserControl
    x:Class="ARZVPRewrite.UI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ico="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:loc="clr-namespace:ARZVPRewrite.Extensions"
    xmlns:local="clr-namespace:ARZVPRewrite.UI.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Background="{DynamicResource PrimaryBackground}"
    FontFamily="{DynamicResource Inter}"
    Foreground="{DynamicResource PrimaryForeground}"
    Loaded="PageLoaded"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ARZVPRewrite;component/UI/Resources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="5"
            Text="{loc:Translation page.settings.language}" />

        <ListBox
            x:Name="LanguageBox"
            Grid.Row="1"
            Margin="5"
            Background="{DynamicResource SecondaryBackground}"
            BorderThickness="0"
            DisplayMemberPath="Name"
            Foreground="{DynamicResource PrimaryForeground}"
            SelectionMode="Single" />

        <Grid Grid.Row="2" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Margin="5"
                VerticalAlignment="Center"
                FontWeight="Medium"
                Text="{loc:Translation page.settings.vlc}" />

            <TextBox
                x:Name="VlcPathBox"
                Grid.Column="1"
                VerticalAlignment="Center"
                Background="{DynamicResource SecondaryBackground}"
                BorderThickness="0"
                FontSize="16"
                Foreground="{DynamicResource PrimaryForeground}" />

            <Button
                x:Name="BrowseVlc"
                Grid.Column="2"
                Margin="5"
                VerticalAlignment="Center"
                Click="BrowseVlcClicked"
                Content="..." />
        </Grid>

        <Button
            x:Name="ApplyBtn"
            Grid.Row="3"
            Margin="5"
            Click="ApplyBtnClicked">
            <Button.Content>
                <StackPanel Orientation="Horizontal">
                    <ico:MaterialIcon IconSize="24" Kind="Check" />
                    <TextBlock
                        Margin="10"
                        VerticalAlignment="Center"
                        FontSize="16"
                        Text="{loc:Translation button.apply}" />
                </StackPanel>
            </Button.Content>
        </Button>
    </Grid>
</UserControl>
