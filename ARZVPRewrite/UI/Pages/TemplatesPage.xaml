<UserControl
    x:Class="ARZVPRewrite.UI.Pages.TemplatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ico="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
    xmlns:loc="clr-namespace:ARZVPRewrite.Extensions"
    xmlns:local="clr-namespace:ARZVPRewrite.UI.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Background="{DynamicResource PrimaryBackground}"
    FontFamily="{DynamicResource Inter}"
    Foreground="{DynamicResource PrimaryForeground}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ARZVPRewrite;component/UI/Resources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Name="TemplateCountLbl"
            Margin="5"
            FontSize="20"
            FontWeight="Bold"
            Text="{loc:Translation page.templates.count}" />

        <TextBlock
            x:Name="SelectedTemplateLbl"
            Grid.Row="1"
            Margin="5"
            Text="{loc:Translation page.templates.selected}" />

        <ListBox
            x:Name="TemplateBox"
            Grid.Row="2"
            Margin="5"
            Background="{DynamicResource SecondaryBackground}"
            BorderThickness="0"
            Foreground="{DynamicResource PrimaryForeground}"
            SelectionChanged="TemplateBoxSelectionChanged"
            SelectionMode="Single" />

        <StackPanel
            Grid.Row="3"
            Margin="5"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Button
                Name="InfoBtn"
                Grid.Row="3"
                Margin="5"
                Click="InfoBtnClicked">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <ico:MaterialIcon IconSize="24" Kind="InfoOutline" />
                        <TextBlock
                            Margin="10"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Text="{loc:Translation button.info}" />
                    </StackPanel>
                </Button.Content>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
